# Copy to .env and fill in your keys. `make run` loads this automatically.
#   cp .env.example .env

# Anthropic API key — https://console.anthropic.com/  (Settings → API Keys)
ANTHROPIC_API_KEY=sk-ant-...

# Telegram bot token — message @BotFather, /newbot, paste the token it gives you.
TELEGRAM_BOT_TOKEN=123456789:ABCdef...

# Postgres DSN. The default points at the `make db` docker container.
# BlueShip auto-migrates its own tables on first start — no manual schema step.
DATABASE_URL=postgres://blueship:blueship@localhost:5432/blueship?sslmode=disable
